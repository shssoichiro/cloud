# Shared secret for internal API calls to the Next.js billing side-effect route.
INTERNAL_API_SECRET=your-internal-api-secret-here

# Shared secret for authenticated calls to the local kiloclaw worker's
# /api/platform/* routes over the service binding.
KILOCLAW_INTERNAL_API_SECRET=your-kiloclaw-internal-api-secret-here

# Backend app origin for local internal API calls.
# @url nextjs
KILOCODE_BACKEND_BASE_URL=http://localhost:3000

# Worker secrets for local dev. In deployed environments, set these with
# wrangler secrets instead of committing them in wrangler.jsonc.
# Canonical KiloClaw Stripe price IDs used for affiliate sale SKU reporting.
STRIPE_KILOCLAW_COMMIT_PRICE_ID=price_commit
STRIPE_KILOCLAW_STANDARD_PRICE_ID=price_standard
STRIPE_KILOCLAW_STANDARD_INTRO_PRICE_ID=price_standard_intro

# Trial inactivity stop rollout flags.
TRIAL_INACTIVITY_STOP_ENABLED=false
TRIAL_INACTIVITY_STOP_DRY_RUN=true

# Snowflake SQL API configuration for trial inactivity stop.
SNOWFLAKE_ACCOUNT_HOST=fyc17898.us-east-1
SNOWFLAKE_JWT_ACCOUNT_IDENTIFIER=FYC17898
SNOWFLAKE_USERNAME=KILOCODE_USER
SNOWFLAKE_ROLE=KILOCODE_ROLE
SNOWFLAKE_WAREHOUSE=WH_KILOCODE
SNOWFLAKE_DATABASE=KILO_DW
SNOWFLAKE_SCHEMA=DBT_PROD
SNOWFLAKE_PUBLIC_KEY_FINGERPRINT=SHA256:your-public-key-fingerprint
SNOWFLAKE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
