{
  "name": "cloudflare-images-mcp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsgo --noEmit --incremental false",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint:fallback",
    "lint:oxlint": "pnpm -w exec oxlint --config .oxlintrc.json cloudflare-images-mcp/src",
    "lint:eslint:fallback": "eslint --config eslint.config.mjs --cache 'src/**/*.ts'",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "aws4fetch": "catalog:",
    "fast-xml-parser": "^5.5.5",
    "fetch-to-node": "^2.1.0",
    "jsonwebtoken": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@kilocode/eslint-config": "workspace:*",
    "@types/jsonwebtoken": "catalog:",
    "@types/node": "^22.19.15",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.2.4",
    "wrangler": "catalog:"
  }
}
