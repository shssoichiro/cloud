{
  "name": "kiloclaw",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Multi-tenant OpenClaw on Fly.io Machines",
  "scripts": {
    "deploy": "wrangler deploy",
    "start": "wrangler dev",
    "dev": "wrangler dev",
    "types": "wrangler types",
    "typecheck": "tsgo --noEmit --incremental false",
    "lint": "eslint --config eslint.config.mjs --cache 'src/**/*.ts'",
    "lint:fix": "eslint --config eslint.config.mjs --cache --fix 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@kilocode/db": "workspace:*",
    "@kilocode/encryption": "workspace:*",
    "@kilocode/worker-utils": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "jose": "^6.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kilocode/eslint-config": "workspace:*",
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "7.0.0-dev.20251019.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.18",
    "wrangler": "catalog:"
  },
  "author": "",
  "license": "Apache-2.0"
}
