# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# editor
.idea/
# so I can colorize multiple clones easily and distinctly:
*.code-workspace

# dependencies
node_modules/
/.pnpm-store/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# local tokens / testing
.tokens.json
.test-token

# testing
/coverage
.tmp/

# next.js
.next/
/out/

# production
/build

# dev server port (written by scripts/dev.sh for multi-worktree support)
.dev-port

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/.dev-logs/
/apps/web/dev/.dev-logs/
/apps/web/dev/*/.dev-logs/
/apps/web/dev/fixtures/
/apps/web/dev/*/fixtures/

# env files (can opt-in for committing if needed)
.env*.local*
!.env*.example*
.env.keys
.env.grafana

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# kdiff3
*.orig
dev-debug-request-logs/*

# misc
.DS_Store
.eslintcache
*.pem
TMP_CI_commit_msg.txt
*.csv

# Sentry Config File
.env.sentry-build-plugin

# Nix / Direnv
.direnv

# Playwright
test-results/
playwright-report/
playwright/.auth/

# Generated screenshot stories
/apps/storybook/stories/generated/
/apps/storybook/public/screenshots/
run-milvus-test.sh

# Cloudflare
.wrangler/
.env*.local
/.superset

# Git worktrees
.worktrees/
.gw.yml

supabase/.temp

# Husky generated hook shims
.husky/_/

.dev-logs/

.kilo/plans

# ESLint cache
.eslintcache

# @kilocode/trpc build output (rebuilt by: pnpm --filter @kilocode/trpc run build)
packages/trpc/dist/
.plan/
