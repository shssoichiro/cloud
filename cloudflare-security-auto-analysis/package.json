{
  "name": "cloudflare-security-auto-analysis",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy:prod": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "dev": "wrangler dev --env dev",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint:fallback",
    "lint:oxlint": "pnpm -w exec oxlint --config .oxlintrc.json cloudflare-security-auto-analysis/src",
    "lint:eslint:fallback": "eslint --config eslint.config.mjs --cache 'src/**/*.ts'",
    "typecheck": "tsgo --noEmit --incremental false",
    "types": "wrangler types --env-interface CloudflareEnv worker-configuration.d.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@kilocode/db": "workspace:*",
    "drizzle-orm": "catalog:",
    "workers-tagged-logger": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kilocode/eslint-config": "workspace:*",
    "@types/node": "^22.19.15",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.2.4",
    "wrangler": "catalog:"
  }
}
