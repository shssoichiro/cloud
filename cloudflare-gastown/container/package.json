{
  "name": "gastown-container",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Town container control server for Gastown agent orchestration",
  "scripts": {
    "start": "bun run src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit --incremental false",
    "lint": "eslint --config eslint.config.mjs --cache 'src/**/*.ts'"
  },
  "dependencies": {
    "@kilocode/plugin": "7.0.37",
    "@kilocode/sdk": "7.0.37",
    "hono": "^4.12.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kilocode/eslint-config": "workspace:*",
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
