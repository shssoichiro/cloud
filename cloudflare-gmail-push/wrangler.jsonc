{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-gmail-push",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "placement": { "mode": "smart" },
  "vars": {
    // Used for OIDC validation when push auth is configured on the Pub/Sub subscription
    "OIDC_AUDIENCE": "https://gmail-push.kilocode.workers.dev"
  },
  "services": [
    {
      "binding": "KILOCLAW",
      "service": "kiloclaw"
    }
  ],
  "secrets_store_secrets": [
    {
      "binding": "INTERNAL_API_SECRET",
      "store_id": "342a86d9e3a94da698e82d0c6e2a36f0",
      "secret_name": "INTERNAL_API_SECRET_PROD"
    }
  ],
  "queues": {
    "producers": [{ "binding": "GMAIL_PUSH_QUEUE", "queue": "gmail-push-notifications" }],
    "consumers": [{ "queue": "gmail-push-notifications", "max_retries": 10, "retry_delay": 60 }]
  },
  "env": {
    "dev": {
      "name": "cloudflare-gmail-push-dev",
      "vars": {
        // Used for OIDC validation when push auth is configured on the Pub/Sub subscription
        "OIDC_AUDIENCE": "https://gmail-push-dev.kilocode.workers.dev"
      },
      "services": [
        {
          "binding": "KILOCLAW",
          "service": "kiloclaw-dev"
        }
      ],
      "secrets_store_secrets": [
        {
          "binding": "INTERNAL_API_SECRET",
          "store_id": "342a86d9e3a94da698e82d0c6e2a36f0",
          "secret_name": "INTERNAL_API_SECRET_DEV"
        }
      ],
      "queues": {
        "producers": [{ "binding": "GMAIL_PUSH_QUEUE", "queue": "gmail-push-notifications-dev" }],
        "consumers": [{ "queue": "gmail-push-notifications-dev", "max_retries": 10, "retry_delay": 60 }]
      }
    }
  }
}
