{
  "name": "app-builder",
  "version": "1.0.0",
  "description": "App Builder",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv worker-configuration.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config eslint.config.mjs --cache 'src/**/*.ts'",
    "test": "vitest run",
    "test:git": "tsx src/_integration_tests/test-git-integration.ts",
    "test:git-head": "tsx src/_integration_tests/test-git-head-and-history.ts",
    "test:git-all": "tsx src/_integration_tests/test-git-integration.ts && tsx src/_integration_tests/test-git-head-and-history.ts"
  },
  "dependencies": {
    "@ashishkumar472/cf-git": "1.0.5",
    "@kilocode/worker-utils": "workspace:*",
    "diff": "^8.0.3",
    "drizzle-orm": "catalog:",
    "jsonwebtoken": "catalog:",
    "workers-tagged-logger": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/containers": "^0.0.30",
    "@cloudflare/sandbox": "0.6.7",
    "@cloudflare/workers-types": "catalog:",
    "@kilocode/eslint-config": "workspace:*",
    "@types/jsonwebtoken": "catalog:",
    "@types/node": "^22.10.1",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "tsx": "^4.7.0",
    "typescript": "catalog:",
    "vitest": "^4.0.18",
    "wrangler": "catalog:"
  }
}
