{
  "name": "kilocode-backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^22"
  },
  "scripts": {
    "dev": "next dev",
    "dev:prod-db": "USE_PRODUCTION_DB=true next dev",
    "build": "next build",
    "start": "next start",
    "stripe": "stripe listen --forward-to http://localhost:3000/api/stripe/webhook",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint:fallback && pnpm -r --filter '!kilocode-backend' --filter '!storybook' run lint",
    "lint:oxlint": "oxlint --config .oxlintrc.json src",
    "lint:eslint:fallback": "eslint --config eslint.fallback.config.mjs --cache --cache-strategy content 'src/**/*.{ts,tsx}'",
    "format": "oxfmt .",
    "format:check": "oxfmt --list-different .",
    "format:changed": "git diff --name-only $(git merge-base origin/main HEAD) --diff-filter=ACMR -- '**/*.js' '**/*.jsx' '**/*.ts' '**/*.tsx' '**/*.json' '**/*.css' '**/*.md' | xargs -r oxfmt --no-error-on-unmatched-pattern",
    "test": "NODE_ENV=test jest",
    "typecheck": "pnpm --filter @kilocode/trpc run build && tsgo --noEmit --incremental false && pnpm -r --filter '!kilocode-backend' --filter '!@kilocode/trpc' run typecheck",
    "dependency-cycle-check": "madge --circular --warning --extensions ts,tsx --ts-config tsconfig.json --basedir . src",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm run format:changed && pnpm run test && pnpm run dependency-cycle-check",
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "node": "node",
    "script": "IS_SCRIPT=true tsx --tsconfig tsconfig.scripts.json",
    "script:run": "tsx --tsconfig tsconfig.scripts.json src/scripts/index",
    "db:empty-database": "tsx --tsconfig tsconfig.scripts.json src/db/empty-database.ts",
    "drizzle": "pnpm --filter @kilocode/db exec drizzle-kit",
    "knip": "knip",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "promo": "pnpm -s script src/scripts/encrypt-promo-codes.ts",
    "dev:discord-gateway-cron": "tsx dev/discord-gateway-cron.ts"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a",
