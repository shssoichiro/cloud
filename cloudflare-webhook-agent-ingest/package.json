{
  "name": "cloudflare-webhook-agent-ingest",
  "version": "1.0.0",
  "private": true,
  "description": "Webhook ingest service for Kilo Cod agents",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "deploy:prod": "wrangler deploy --env=\"\"",
    "deploy:dev": "wrangler deploy --env dev",
    "dev": "wrangler dev --env dev",
    "start": "wrangler dev --env dev",
    "types": "wrangler types",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint:fallback",
    "lint:oxlint": "pnpm -w exec oxlint --config .oxlintrc.json cloudflare-webhook-agent-ingest/src",
    "lint:eslint:fallback": "eslint --config eslint.config.mjs --cache 'src/**/*.ts'",
    "lint:fix": "eslint --config eslint.config.mjs --cache --fix 'src/**/*.ts'",
    "format": "oxfmt src",
    "format:check": "oxfmt --list-different src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.workers.config.ts",
    "test:integration:watch": "vitest --config vitest.workers.config.ts",
    "typecheck": "tsgo --noEmit --incremental false"
  },
  "dependencies": {
    "@kilocode/db": "workspace:*",
    "@kilocode/encryption": "workspace:*",
    "@kilocode/worker-utils": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "workers-tagged-logger": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@kilocode/eslint-config": "workspace:*",
    "@types/node": "^22.19.15",
    "@typescript/native-preview": "catalog:",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.2.4",
    "wrangler": "catalog:"
  }
}
