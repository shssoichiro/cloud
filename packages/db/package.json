{
  "name": "@kilocode/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsgo --noEmit --incremental false",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint:fallback",
    "lint:oxlint": "pnpm -w exec oxlint --config .oxlintrc.json packages/db/src",
    "lint:eslint:fallback": "eslint --config eslint.config.mjs --cache 'src/**/*.ts'"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./schema-types": "./src/schema-types.ts",
    "./client": "./src/client.ts"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kilocode/eslint-config": "workspace:*",
    "@types/pg": "^8.18.0",
    "@typescript/native-preview": "catalog:",
    "drizzle-kit": "^0.31.9",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
