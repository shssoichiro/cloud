{
  "name": "cloudflare-git-token-service",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:test": "wrangler dev --config wrangler.test.jsonc",
    "deploy": "wrangler deploy",
    "typecheck": "tsgo --noEmit --incremental false",
    "lint": "eslint --config eslint.config.mjs --cache 'src/**/*.ts'",
    "types": "wrangler types --env-interface CloudflareEnv worker-configuration.d.ts"
  },
  "dependencies": {
    "@kilocode/db": "workspace:*",
    "@octokit/auth-app": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kilocode/eslint-config": "workspace:*",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
